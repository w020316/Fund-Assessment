# ===== Application =====
# Server host (0.0.0.0 for all interfaces)
HOST=0.0.0.0
# Server port (cloud platforms auto-assign via $PORT)
PORT=8000

# ===== AI API Keys =====
TTAPI_API_KEY=your_ttapi_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
TINYFISH_API_KEY=your_tinyfish_api_key_here

# ===== LLM Router (Multi-Provider) =====
# TTAPI (OpenAI Compatible)
TTAPI_API_KEY=
TTAPI_BASE_URL=https://ttapi.io/v1
TTAPI_MODEL=gpt-4o

# DeepSeek (OpenAI Compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (Local LLM)
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen2.5:7b

# ===== Search Engines =====
SERPAPI_KEY=
BING_SEARCH_KEY=

# ===== CORS =====
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ===== Tushare API Token =====
TUSHARE_TOKEN=your_tushare_token_here

# ===== Broker API =====
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ID=

# ===== DingTalk Notification =====
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# ===== WeChat Work Notification =====
WECHAT_WEBHOOK=

# ===== App Settings (override config/settings.yaml via APP_ prefix) =====
# Example: APP_SETTINGS__BROKER__TYPE=simulated
# Example: APP_SETTINGS__APP__DEBUG=false
APP_SETTINGS__BROKER__TYPE=simulated
APP_SETTINGS__APP__DEBUG=false
